; ---------- Q1 交易 ----------
; 买入 AAPL
2023-01-10 * "买入苹果股票"
  Assets:Brokerage:Stocks  100 AAPL {150.00 USD}
  Assets:Bank:Checking  -15000.00 USD

; 买入 GOOGL
2023-01-15 * "买入谷歌股票"
  Assets:Brokerage:Stocks  50 GOOGL {90.00 USD}
  Assets:Bank:Checking  -4500.00 USD

; 工资收入
2023-01-20 * "工资收入"
  Assets:Bank:Checking  8000.00 USD
  Income:Salary

; 买入 MSFT
2023-02-01 * "买入微软股票"
  Assets:Brokerage:Stocks  30 MSFT {240.00 USD}
  Assets:Bank:Checking  -7200.00 USD

; 买入 ETF
2023-02-15 * "买入标普500 ETF"
  Assets:Brokerage:Stocks  20 VOO {350.00 USD}
  Assets:Bank:Checking  -7000.00 USD

; 外汇兑换
2023-02-20 * "兑换人民币"
  Assets:Forex  10000.00 CNY @@ 1450.00 USD
  Assets:Bank:Checking

; 卖出部分 AAPL（盈利）
2023-03-15 * "卖出部分苹果股票"
  Assets:Brokerage:Stocks  -50 AAPL {150.00 USD}
  Assets:Bank:Checking  8250.00 USD
  Income:Investments:CapitalGains  -750.00 USD

