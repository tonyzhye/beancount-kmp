option "title" "投资组合 2023"
option "operating_currency" "USD"

; ---------- 商品定义 ----------
2023-01-01 commodity USD
2023-01-01 commodity CNY
2023-01-01 commodity EUR
2023-01-01 commodity AAPL
2023-01-01 commodity GOOGL
2023-01-01 commodity MSFT
2023-01-01 commodity VOO
2023-01-01 commodity BTC

; ---------- 账户开设 ----------
2023-01-01 open Assets:Brokerage:Stocks AAPL,GOOGL,MSFT,VOO
2023-01-01 open Assets:Brokerage:Crypto BTC
2023-01-01 open Assets:Bank:Checking USD,CNY
2023-01-01 open Assets:Bank:Savings USD
2023-01-01 open Assets:Forex CNY,EUR
2023-01-01 open Liabilities:Margin USD
2023-01-01 open Equity:OpeningBalances

; 收入账户
2023-01-01 open Income:Investments:Dividends USD
2023-01-01 open Income:Investments:CapitalGains USD
2023-01-01 open Income:Salary USD

; 支出账户
2023-01-01 open Expenses:Financial:Fees USD
2023-01-01 open Expenses:Financial:Interest USD

